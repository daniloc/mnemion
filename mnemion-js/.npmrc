# `agents` (>=0.16) and `@modelcontextprotocol/ext-apps` both declare `react`
# (and ext-apps `react-dom`) as NON-optional peerDependencies, for their React
# chat/UI integrations. This is a Cloudflare Workers project — it never imports
# React; the worker uses only `agents`' McpAgent and ext-apps' self-contained
# `app-with-deps` client entry. legacy-peer-deps keeps npm from pulling phantom
# react/react-dom into the tree (and lets `npm install`/`npm ci` succeed in CI
# Workers Builds + one-click installs). Drop if React ever becomes a real dep,
# or once those packages mark react optional.
legacy-peer-deps=true
