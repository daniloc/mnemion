# @modelcontextprotocol/ext-apps peer-requires @modelcontextprotocol/sdk ^1.29,
# but the worker pins SDK 1.26 to match the `agents` package's bundled copy. The
# worker never imports ext-apps — only the client fragment bundle does, via the
# self-contained `ext-apps/app-with-deps` entry — so the mismatch is inert. This
# lets `npm install` / `npm ci` succeed in CI (Workers Builds) and one-click
# installs. Remove once `agents` (and the pinned SDK) move to >=1.29.
legacy-peer-deps=true
