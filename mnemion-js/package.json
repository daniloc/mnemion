{
  "name": "mnemion",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:pages": "vite build --config vite.canvas.ts && vite build --config vite.fragment.ts && vite build",
    "build:web": "vite build --config vite.web.ts",
    "preview:render": "vite dev --config vite.preview.ts --open /render-preview.html",
    "dev": "concurrently -k -n worker,app -c blue,green \"npm:dev:worker\" \"npm:dev:app\"",
    "dev:worker": "DEV=1 wrangler dev --var DEV_SEED:true --var SKIP_EMBED:1 --port 4281",
    "dev:app": "vite dev --config vite.web.ts",
    "dev:built": "npm run build:pages && npm run build:web && wrangler dev --var DEV_SEED:true",
    "deploy": "npm run build:pages && npm run build:web && wrangler deploy",
    "types": "wrangler types",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup": "bash scripts/setup.sh",
    "enable-documents": "bash scripts/enable-documents.sh",
    "coherence:docs": "coherence docs",
    "coherence:verify": "coherence verify",
    "coherence:onboard": "coherence onboard"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.8.0",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@simplewebauthn/server": "^13.3.1",
    "agents": "^0.16.0",
    "fflate": "^0.8.3",
    "konva": "^10.3.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "svelte": "^5.53.10",
    "svelte-konva": "^1.0.1",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.15",
    "@cloudflare/workers-types": "^4.20260615.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.0.0",
    "coherence-harness": "github:daniloc/coherence",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^25.9.3",
    "ai": "^6.0.206",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wrangler": "^4.100.0"
  }
}
