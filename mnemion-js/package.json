{
  "name": "mnemion",
  "version": "0.5.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build:pages": "vite build --config vite.fragment.ts",
    "build:web": "vite build --config vite.web.ts",
    "preview:render": "vite dev --config vite.preview.ts --open /render-preview.html",
    "dev": "concurrently -k -n worker,app -c blue,green \"npm:dev:worker\" \"npm:dev:app\"",
    "dev:worker": "wrangler dev --var DEV:true --var DEV_SEED:true --var SKIP_EMBED:1 --port 4281",
    "dev:app": "vite dev --config vite.web.ts",
    "dev:built": "npm run build:pages && npm run build:web && wrangler dev --var DEV:true --var DEV_SEED:true",
    "deploy": "npm run build:pages && npm run build:web && wrangler deploy",
    "types": "wrangler types",
    "typecheck": "tsc -p tsconfig.json && tsc -p src/pages/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "mcp:smoke": "node scripts/mcp-smoke.mjs",
    "setup": "bash scripts/setup.sh",
    "enable-documents": "bash scripts/enable-documents.sh",
    "coherence:docs": "coherence docs",
    "coherence:docs:check": "coherence docs --check",
    "coherence:claude": "coherence claude",
    "coherence:verify": "coherence verify --fast",
    "coherence:verify:full": "coherence verify",
    "coherence:verify:staged": "coherence verify --fast --staged",
    "coherence:log": "coherence log",
    "coherence:decompose": "coherence decompose",
    "coherence:drift": "coherence drift",
    "coherence:onboard": "coherence onboard",
    "conventions": "coherence conventions",
    "conventions:check": "coherence conventions --check",
    "injection-lint": "coherence lint-sinks",
    "injection-lint:check": "coherence lint-sinks --check",
    "atlas": "coherence atlas",
    "atlas:check": "coherence atlas --check",
    "why-lint": "coherence why-lint",
    "cruft": "npx --yes ts-prune -p tsconfig.json | grep -v 'used in module'"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.8.0",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@resvg/resvg-wasm": "^2.6.2",
    "@simplewebauthn/server": "^13.3.1",
    "agents": "^0.16.0",
    "fflate": "^0.8.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-is": "^19.2.7",
    "recharts": "^3.8.1",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.15",
    "@cloudflare/workers-types": "^4.20260615.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "ai": "^6.0.206",
    "coherence-harness": "github:daniloc/coherence#v0.5.0",
    "concurrently": "^9.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wrangler": "^4.100.0"
  }
}
