{
  "name": "mnemion",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:pages": "vite build && vite build --config vite.canvas.ts && vite build --config vite.fragment.ts && vite build --ssr",
    "preview": "vite dev --config vite.preview.ts",
    "dev": "npm run build:pages && wrangler dev --var DEV_SEED:true",
    "deploy": "npm run build:pages && wrangler deploy",
    "types": "wrangler types",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup": "bash scripts/setup.sh",
    "enable-documents": "bash scripts/enable-documents.sh"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.3.0",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "1.26.0",
    "@simplewebauthn/server": "^13.3.1",
    "agents": "^0.7.5",
    "fflate": "^0.8.3",
    "konva": "^10.3.0",
    "svelte": "^5.53.10",
    "svelte-konva": "^1.0.1",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.15",
    "@cloudflare/workers-types": "^4.20260615.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^25.9.3",
    "ai": "^6.0.206",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wrangler": "^4.100.0"
  }
}
