{
  "name": "mnemion",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:pages": "vite build && vite build --ssr src/pages/entry-server.ts",
    "preview": "vite dev --config vite.preview.ts",
    "dev": "npm run build:pages && wrangler dev",
    "deploy": "npm run build:pages && wrangler deploy",
    "types": "wrangler types",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup": "bash scripts/setup.sh"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@simplewebauthn/server": "^13.2.3",
    "agents": "^0.7.5",
    "fflate": "^0.8.2",
    "svelte": "^5.53.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.20",
    "@cloudflare/workers-types": "^4.20260307.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/node": "^25.3.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "~3.2.0",
    "wrangler": "^4.71.0"
  }
}
